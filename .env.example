# =============================================================
# Autenticação Cobli (preencher pelo menos uma das duas)
# =============================================================
# A API GraphQL da Cobli espera o session id da UI no header
# `cobli-api-sid`. Para obter:
#   1. Acesse https://painel.cobli.co/ logado
#   2. F12 -> Network -> qualquer chamada -> Headers -> cobli-api-sid
#   3. Copie o valor (longo, alfanumérico) e cole abaixo
# Atenção: o SID expira em algumas horas. Quando receber 401 nas
# chamadas, basta renovar o valor.
COBLI_API_SID=

# Chave de API REST gerada no painel (Integrações > APIs > Criar chave).
# Está aqui como fallback. A API REST /public/v1/routes está com bug
# (retorna 400 com corpo vazio), então o código usa GraphQL.
COBLI_API_KEY=

# =============================================================
# Google Sheets
# =============================================================
# ID da planilha (parte da URL entre /d/ e /edit)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Rota_do_Dia
GOOGLE_CREDENTIALS_PATH=./credentials.json

# =============================================================
# Defaults da operação
# =============================================================
CIDADE_PADRAO=Curitiba
ESTADO_PADRAO=PR
PAIS_PADRAO=BR

# =============================================================
# Ponto de partida (depósito) - obrigatório
# =============================================================
# Endereço completo + coordenadas (pegue no Google Maps com clique direito)
DEPOSITO_ENDERECO=Rua Exemplo, 100, Bairro, Cidade - UF, 00000-000, Brasil
DEPOSITO_LATITUDE=0.0000000
DEPOSITO_LONGITUDE=0.0000000
